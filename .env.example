# Repo root — API, worker, Prisma (not Next.js).
# Web (NEXT_PUBLIC_*): copy apps/web/.env.example to apps/web/.env.local

# API (optional public URL for stored music playback links)
API_PORT=3001
API_PUBLIC_URL=http://localhost:3001
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_music
REDIS_URL=redis://localhost:6379

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# AI providers — music generation (MUSIC_PROVIDER selects vendor)
MUSIC_PROVIDER=sunoapi
SUNO_API_BASE_URL=https://api.sunoapi.org
SUNO_API_KEY=
SUNO_API_MODEL=V4_5ALL
# Required for Suno Voice persona (voice_persona works only on V5 / V5_5)
SUNO_VOICE_MODEL=V5
# Suno requires callBackUrl in requests; webhook syncs status when SUNO_CALLBACK_URL is public HTTPS
SUNO_CALLBACK_URL=http://localhost:3001/api/music/callback/suno
SUNO_REQUEST_TIMEOUT_MS=30000
SUNO_POLL_INTERVAL_MS=5000
SUNO_POLL_TIMEOUT_MS=600000
# Suno submit rate limit (shared Redis bucket across API + workers)
SUNO_RATE_LIMIT_MAX=18
SUNO_RATE_LIMIT_WINDOW_MS=10000
SUNO_RATE_LIMIT_MAX_WAIT_MS=120000
# Worker: parallel provider jobs (use with SUNO_RATE_LIMIT_*; scale with multiple worker processes)
WORKER_PROVIDER_CONCURRENCY=4
# Suno Voice: file upload host (separate from api.sunoapi.org)
SUNO_FILE_UPLOAD_BASE_URL=https://sunoapiorg.redpandaai.co
# Validation phrase language: ru, en, etc.
SUNO_VOICE_LANGUAGE=ru

# AI providers — Kits voice transfer (editor: separation, conversion on stems)
KITS_API_BASE_URL=https://arpeggi.io/api/kits/v1
KITS_API_KEY=

# Web CORS (API)
WEB_ORIGIN=http://localhost:3000

# Stripe billing (API only) — see docs/billing-stripe-local-setup.md
# STRIPE_SECRET_KEY: Dashboard → Developers → API keys (sk_test_... / sk_live_...)
# STRIPE_WEBHOOK_SECRET: stripe listen (local) or Dashboard webhook endpoint (whsec_...)
# STRIPE_PRICE_*: pnpm --filter @ai-music/api setup-stripe-billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_STUDIO=

# Auth: CLERK_SECRET_KEY required; AUTH_DEV_MODE=false for Clerk-only API
CLERK_SECRET_KEY=
AUTH_DEV_MODE=false
AUTH_DEV_USER_EMAIL=dev@local.test
AUTH_DEV_USER_NAME=Dev User

# Admin (dev/QA) — see docs/admin-dev-testing-flow.md
ADMIN_EMAILS=
ADMIN_USER_IDS=
ADMIN_API_ENABLED=false

# Local file storage (dev)
STORAGE_LOCAL_PATH=./storage

# Editor render — optional path to ffmpeg binary (default: bundled ffmpeg-static)
# FFMPEG_PATH=/opt/homebrew/bin/ffmpeg
