# Web
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_DEV_AUTH_USER_ID=local-user-1

# API (optional public URL for stored music playback links)
API_PORT=3001
API_PUBLIC_URL=http://localhost:3001
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_music
REDIS_URL=redis://localhost:6379

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# AI providers — music generation (MUSIC_PROVIDER selects vendor)
MUSIC_PROVIDER=sunoapi
SUNO_API_BASE_URL=https://api.sunoapi.org
SUNO_API_KEY=
SUNO_API_MODEL=V4_5ALL
# Suno requires callBackUrl in requests; polling is primary, webhook optional later
SUNO_CALLBACK_URL=http://localhost:3001/api/music/callback/suno
SUNO_REQUEST_TIMEOUT_MS=30000
SUNO_POLL_INTERVAL_MS=5000
SUNO_POLL_TIMEOUT_MS=600000

# AI providers — Kits voice transfer (separate from music generation)
KITS_API_BASE_URL=https://arpeggi.io/api/kits/v1
KITS_API_KEY=
KITS_TEST_VOICE_MODEL_ID=1014961

# Web CORS (API)
WEB_ORIGIN=http://localhost:3000

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Auth (Clerk or dev mode)
CLERK_SECRET_KEY=
AUTH_DEV_MODE=true
AUTH_DEV_USER_EMAIL=dev@local.test
AUTH_DEV_USER_NAME=Dev User

# Local file storage (dev)
STORAGE_LOCAL_PATH=./storage
