generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  voiceSamples       VoiceSample[]
  tracks             Track[]
  generationJobs     GenerationJob[]
  musicGenerations   MusicGeneration[]
  creditTransactions CreditTransaction[]
  songs              Song[]

  @@map("users")
}

model VoiceSample {
  id               String   @id @default(cuid())
  userId           String   @map("user_id")
  r2Key            String   @map("r2_key")
  durationSec      Int      @map("duration_sec")
  status           String   @default("pending")
  consentConfirmed Boolean  @default(false) @map("consent_confirmed")
  kitsVoiceModelId Int?     @map("kits_voice_model_id")
  createdAt        DateTime @default(now()) @map("created_at")

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  generationJobs GenerationJob[]

  @@map("voice_samples")
}

model Track {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  title       String
  prompt      String
  style       String
  durationSec Int      @map("duration_sec")
  audioR2Key  String   @map("audio_r2_key")
  coverR2Key  String?  @map("cover_r2_key")
  shareSlug   String   @unique @map("share_slug")
  createdAt   DateTime @default(now()) @map("created_at")

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  generationJobs GenerationJob[]

  @@map("tracks")
}

model GenerationJob {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  voiceSampleId String   @map("voice_sample_id")
  trackId       String?  @map("track_id")
  prompt        String
  style         String
  durationSec   Int      @map("duration_sec")
  status        String   @default("pending")
  errorMessage  String?  @map("error_message")
  providerJobId String?  @map("provider_job_id")
  creditsCost   Int      @map("credits_cost")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  voiceSample VoiceSample @relation(fields: [voiceSampleId], references: [id])
  track       Track?      @relation(fields: [trackId], references: [id])

  @@map("generation_jobs")
}

model MusicGeneration {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  type           String
  providerTaskId String   @unique @map("provider_task_id")
  prompt         String
  style          String?
  title          String?
  customMode     Boolean  @default(false) @map("custom_mode")
  instrumental   Boolean  @default(false)
  status         String   @default("pending")
  rawStatus      String?  @map("raw_status")
  errorMessage   String?  @map("error_message")
  lyricsResult   Json?    @map("lyrics_result")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user   User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tracks MusicGenerationTrack[]

  @@index([userId, createdAt(sort: Desc)])
  @@map("music_generations")
}

model MusicGenerationTrack {
  id                String   @id @default(cuid())
  musicGenerationId String   @map("music_generation_id")
  providerTrackId   String   @map("provider_track_id")
  title             String
  durationSec       Int?     @map("duration_sec")
  audioStorageKey   String?  @map("audio_storage_key")
  audioSourceUrl    String?  @map("audio_source_url")
  imageSourceUrl    String?  @map("image_source_url")
  lyricsText        String?  @map("lyrics_text")
  createdAt         DateTime @default(now()) @map("created_at")

  musicGeneration MusicGeneration @relation(fields: [musicGenerationId], references: [id], onDelete: Cascade)
  song            Song?

  @@unique([musicGenerationId, providerTrackId])
  @@map("music_generation_tracks")
}

model Song {
  id                   String   @id @default(cuid())
  userId               String   @map("user_id")
  sourceTrackId        String   @unique @map("source_track_id")
  provider             String   @default("sunoapi")
  providerTaskId       String   @map("provider_task_id")
  providerTrackId      String   @map("provider_track_id")
  prompt               String
  title                String
  status               String   @default("pending_stems")
  audioStorageKey      String?  @map("audio_storage_key")
  durationMs           Int?     @map("duration_ms")
  stemSeparationTaskId String?  @map("stem_separation_task_id")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  user         User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceTrack  MusicGenerationTrack  @relation(fields: [sourceTrackId], references: [id], onDelete: Cascade)
  stems        SongStem[]
  regions      SongRegion[]
  versions     SongVersion[]
  renderJobs   RenderJob[]

  @@index([userId, createdAt(sort: Desc)])
  @@map("songs")
}

model SongStem {
  id              String   @id @default(cuid())
  songId          String   @map("song_id")
  type            String
  audioStorageKey String   @map("audio_storage_key")
  durationMs      Int?     @map("duration_ms")
  createdAt       DateTime @default(now()) @map("created_at")

  song Song @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@unique([songId, type])
  @@map("song_stems")
}

model SongRegion {
  id         String   @id @default(cuid())
  songId     String   @map("song_id")
  label      String
  startMs    Int      @map("start_ms")
  endMs      Int      @map("end_ms")
  orderIndex Int      @map("order_index")
  createdAt  DateTime @default(now()) @map("created_at")

  song Song @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@index([songId, orderIndex])
  @@map("song_regions")
}

model SongVersion {
  id               String   @id @default(cuid())
  songId           String   @map("song_id")
  versionNumber    Int      @map("version_number")
  renderedAudioKey String?  @map("rendered_audio_key")
  status           String   @default("draft")
  createdAt        DateTime @default(now()) @map("created_at")

  song       Song            @relation(fields: [songId], references: [id], onDelete: Cascade)
  operations EditOperation[]
  renderJobs RenderJob[]

  @@unique([songId, versionNumber])
  @@map("song_versions")
}

model EditOperation {
  id            String   @id @default(cuid())
  songVersionId String   @map("song_version_id")
  operationType String   @map("operation_type")
  payloadJson   Json     @map("payload_json")
  createdAt     DateTime @default(now()) @map("created_at")

  songVersion SongVersion @relation(fields: [songVersionId], references: [id], onDelete: Cascade)

  @@index([songVersionId, createdAt])
  @@map("edit_operations")
}

model RenderJob {
  id            String   @id @default(cuid())
  songId        String   @map("song_id")
  songVersionId String   @map("song_version_id")
  status        String   @default("pending")
  errorMessage  String?  @map("error_message")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  song        Song        @relation(fields: [songId], references: [id], onDelete: Cascade)
  songVersion SongVersion @relation(fields: [songVersionId], references: [id], onDelete: Cascade)

  @@index([songId, createdAt(sort: Desc)])
  @@map("render_jobs")
}

model CreditTransaction {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  type            String
  amount          Int
  reason          String
  stripePaymentId String?  @map("stripe_payment_id")
  createdAt       DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("credit_transactions")
}
